# ==========================================================================
# Archivo de ejemplo de variables de entorno.
# Copialo a ".env" (sin ".example") y completá los valores.
#   cp .env.example .env
# Docker Compose lee ".env" automáticamente. El ".env" real NO se sube a git.
# ==========================================================================

# ---- RabbitMQ ----
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ==========================================================================
# Credenciales de TU TP (ejemplos - descomentá y usá las que necesites).
# Estas NO están cableadas todavía: cuando agregues la integración,
# leelas en tu application.properties con ${NOMBRE_VARIABLE}.
# ==========================================================================

# API key de un proveedor externo (ej. WeatherAPI, etc.)
# API_KEY=tu_api_key_aca

# SMTP para enviar mails (ej. Mailtrap / Gmail)
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=tu_usuario
# MAIL_PASSWORD=tu_password
